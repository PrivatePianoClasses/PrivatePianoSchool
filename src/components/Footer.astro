---
const year = new Date().getFullYear();
---
<footer class="footer">
    <div class="contactbar">
        <div class="phone">
            <p class="contactbar-title">Contact by Phone</p>
            <p class="contactbar-info">410-812-1991</p>
        </div>
        <div class="email">
            <p class="contactbar-title">Contact by Email</p>
            <p class="contactbar-info">deolivera777@gmail.com</p>
        </div>
    </div>
    <div class="bottom">
        <span class="copyright footertext">&copy; {year} Deborah Cobb, All Rights Reserved</span>
    </div>
  </footer>

  <style>
    .contactbar {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-evenly;
        align-items: center;
        text-align: center;
        background-color: var(--primary);
        padding: 7em 2em;
    }
    .contactbar-title {
        font-style: italic;
    }
    .contactbar-info {
        font-weight: 700;
        font-size: 1.5em;
    }
    .bottom {
        text-align: center;
        padding: 2em;
    }
    .footertext {
        font-size: .7em;
    }

    @media (max-width: 800px) {
        .contactbar {
            gap: 4em;
        }
    }
  </style>
