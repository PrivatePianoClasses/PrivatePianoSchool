---
const year = new Date().getFullYear();
---
<footer class="footer">
    <div class="contactbar">
        <div class="phone">
            <p class="contactbar-title">Contact by Phone</p>
            <p class="contactbar-info">410-812-1991</p>
        </div>
        <div class="email">
            <p class="contactbar-title">Contact by Email</p>
            <p class="contactbar-info">deolivera777@gmail.com</p>
        </div>
    </div>
    <div class="bottom">
        <span class="copyright footertext">&copy; {year} Deborah Cobb, All Rights Reserved</span>
        <span class="separator footertext"> | </span>
        <span class="author footertext">
            Made with
            <svg data-sanity-icon="heart-filled" width="1em" height="1em" viewBox="0 0 25 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M17 16C15.8 17.3235 12.5 20.5 12.5 20.5C12.5 20.5 9.2 17.3235 8 16C5.2 12.9118 4.5 11.7059 4.5 9.5C4.5 7.29412 6.1 5.5 8.5 5.5C10.5 5.5 11.7 6.82353 12.5 8.14706C13.3 6.82353 14.5 5.5 16.5 5.5C18.9 5.5 20.5 7.29412 20.5 9.5C20.5 11.7059 19.8 12.9118 17 16Z" fill="currentColor" stroke="currentColor" stroke-width="1.2"></path>
            </svg> by <a href="https://theramoshe.com">theRamoShe</a>
        </span>
    </div>
  </footer>

  <style>
    .contactbar {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-evenly;
        align-items: center;
        text-align: center;
        background-color: var(--primary);
        padding: 7em 2em;
    }
    .contactbar-title {
        font-style: italic;
    }
    .contactbar-info {
        font-weight: 700;
        font-size: 1.5em;
    }
    .bottom {
        text-align: center;
        padding: 2em;
    }
    .footertext {
        font-size: .7em;
    }

    @media (max-width: 800px) {
        .contactbar {
            gap: 4em;
        }
    }
  </style>