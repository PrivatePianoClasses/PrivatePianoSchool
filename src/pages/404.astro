---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found">
    <section class="content">
        <h2 class="title">You've entered a URL that wasn't found on this site.</h2>
        <p class="text">Please <a href="/" class="homelink">return to the home page</a> to continue exploring the site.</p>
    </section>
</Layout>

<style>
  .content {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    min-height: 50vh;
  }
  .text {
    margin-top: 2em;
    font-size: 1.2em;
  }
</style>